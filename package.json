{
  "name": "md2docx-plugin-template",
  "private": true,
  "scripts": {
    "build": "turbo build",
    "clean": "turbo clean",
    "dev": "turbo dev",
    "format": "biome check . --write",
    "lint": "biome check .",
    "lint:fix": "biome check . --write",
    "sync": "turborepo-template-upgrade",
    "test": "turbo test",
    "typecheck": "turbo typecheck",
    "doc": "tsx scripts/doc.ts && typedoc && cp _config.yml docs && tsx scripts/add-frontmatter.ts",
    "prepare": "husky",
    "release": "tsx ./scripts/publish.ts",
    "upgrade": "tsx ./scripts/upgrade.ts"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.9",
    "@changesets/cli": "^2.31.1",
    "@repo/typescript-config": "workspace:*",
    "@types/node": "^25.9.5",
    "husky": "^9.1.7",
    "tsx": "^4.23.1",
    "turbo": "^2.10.6",
    "turborepo-template-upgrade": "^0.8.0"
  },
  "packageManager": "pnpm@10.33.4",
  "engines": {
    "node": ">=20"
  },
  "pnpm": {
    "overrides": {
      "cross-spawn@<6.0.6": ">=6.0.6"
    }
  },
  "dependencies": {
    "@promptshield/cli": "^1.2.0"
  }
}
